[Unit]
Description=Tuitional AI — Backend API Server
After=network.target postgresql.service

[Service]
Type=simple
User=tuitional
WorkingDirectory=/opt/tuitional/backend
EnvironmentFile=/opt/tuitional/backend/.env
ExecStart=/usr/bin/node dist/index.js
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tuitional-app

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/tuitional/backend

[Install]
WantedBy=multi-user.target
